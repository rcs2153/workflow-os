{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-os.dev/schemas/v0/policy.schema.json",
  "title": "Workflow OS v0 Policy Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "name"],
  "properties": {
    "schema_version": { "const": "workflowos.dev/v0" },
    "id": { "$ref": "#/$defs/identifier" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/policy_rule" },
      "default": []
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._\\-/]+$"
    },
    "policy_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "effect"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "effect": { "type": "string", "minLength": 1 },
        "actor": { "$ref": "#/$defs/identifier" }
      }
    }
  }
}
